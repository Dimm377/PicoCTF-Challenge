{
  // ═══════════════════════════════════════════════
  //  TYPOGRAPHY & READABILITY
  // ═══════════════════════════════════════════════
  "editor.fontFamily": "'CaskaydiaCove Nerd Font', 'JetBrains Mono', 'Fira Code', monospace",
  "editor.fontSize": 16,
  "editor.lineHeight": 1.6,
  "editor.letterSpacing": 0.3,
  "editor.fontLigatures": true,
  // ═══════════════════════════════════════════════
  //  COZY CURSOR & ANIMATIONS
  // ═══════════════════════════════════════════════
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 2,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,
  // ═══════════════════════════════════════════════
  //  WRITING COMFORT (MARKDOWN FOCUSED)
  // ═══════════════════════════════════════════════
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 100,
  "editor.rulers": [
    100
  ],
  "editor.renderWhitespace": "trailing",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.linkedEditing": true,
  "editor.suggest.showWords": false,
  "window.zoomLevel": 1.5,
  // ═══════════════════════════════════════════════
  //  CLEAN UI
  // ═══════════════════════════════════════════════
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.renderLineHighlight": "gutter",
  "breadcrumbs.enabled": true,
  "editor.scrollbar.verticalScrollbarSize": 8,
  "editor.scrollbar.horizontalScrollbarSize": 8,
  "editor.padding.top": 12,
  "editor.padding.bottom": 12,
  "workbench.editor.tabSizing": "shrink",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  // ═══════════════════════════════════════════════
  //  AUTO-SAVE & FILE HYGIENE
  // ═══════════════════════════════════════════════
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  // ═══════════════════════════════════════════════
  //  INDENTATION
  // ═══════════════════════════════════════════════
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "[python]": {
    "editor.tabSize": 4
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "files.trimTrailingWhitespace": false,
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  },
  // ═══════════════════════════════════════════════
  //  MARKDOWN SPECIFIC
  // ═══════════════════════════════════════════════
  "markdown.preview.fontFamily": "'JetBrains Mono NF', 'Segoe UI', sans-serif",
  "markdown.preview.fontSize": 14,
  "markdown.preview.lineHeight": 1.6,
  "markdown.editor.pasteUrlAsFormattedLink.enabled": "smart",
  // ═══════════════════════════════════════════════
  //  TERMINAL
  // ═══════════════════════════════════════════════
  "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  // ═══════════════════════════════════════════════
  //  FILE EXPLORER
  // ═══════════════════════════════════════════════
  "explorer.sortOrder": "type",
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  // ═══════════════════════════════════════════════
  //  SEARCH
  // ═══════════════════════════════════════════════
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true
  },
  "search.smartCase": true
}
